#!/bin/sh
# Pre-commit checks (CLAUDE.md). Enable once per clone: git config core.hooksPath .githooks

# 1. Never commit directly to main — work on a branch and open a PR.
branch=$(git branch --show-current 2>/dev/null)
if [ "$branch" = "main" ]; then
  echo "pre-commit: direct commits to 'main' are not allowed — create a branch and open a PR."
  exit 1
fi

# 2. Run ruff (resolves it from the project's .venv first, then the PATH).
if [ -x ".venv/bin/ruff" ]; then
  RUFF=".venv/bin/ruff"
elif command -v ruff >/dev/null 2>&1; then
  RUFF="ruff"
else
  echo "pre-commit: ruff not found. Install dev deps: pip install -r requirements-dev.txt"
  exit 1
fi

"$RUFF" check src/ || {
  echo "pre-commit: ruff check failed — fix the issues above or run '$RUFF check --fix src/'."
  exit 1
}
